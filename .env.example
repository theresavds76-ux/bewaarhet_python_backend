# Bewaarhet example environment
# Copy this file to .env and replace placeholders with real values.
# Never commit .env or real secrets.

# Zoho IMAP/SMTP
ZOHO_EMAIL=service@bewaarhet.nl
ZOHO_IMAP_HOST=imap.zoho.eu
ZOHO_IMAP_PORT=993
ZOHO_SMTP_HOST=smtp.zoho.eu
ZOHO_SMTP_PORT=587
ZOHO_APP_PASSWORD=replace_with_zoho_app_password

# Dropbox
# Current code uses refresh-token flow. DROPBOX_ACCESS_TOKEN is deprecated and not read by the app.
DROPBOX_REFRESH_TOKEN=replace_with_dropbox_refresh_token
DROPBOX_APP_KEY=replace_with_dropbox_app_key
DROPBOX_APP_SECRET=replace_with_dropbox_app_secret
DROPBOX_BASE_PATH=/Bewaar het/Klanten
DROPBOX_TIMEOUT_SECONDS=15

# OCR.space
OCR_SPACE_API_KEY=replace_with_ocr_space_api_key
OCR_SPACE_LANGUAGE=dut

# OpenAI fallback, optional
# Used only when rule-based classification returns uncertainty.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Runtime paths
DATA_DIR=data
DATABASE_PATH=data/bewaarhet.sqlite3
BACKUP_DIR=data/backups
LOG_DIR=data/logs

# Backups and maintenance
BACKUP_KEEP_LATEST=14
CONSISTENCY_LOG_EVERY=10
CONSISTENCY_SLOW_THRESHOLD_SECONDS=2.0

# Worker behavior
POLL_SECONDS=60
SEARCH_RESULT_LIMIT=10

# Upload safety
MAX_ATTACHMENT_MB=15
ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.docx,.xlsx,.csv,.txt,.zip

# Rate limits are currently defined in code in bewaarhet/rate_limiter.py.
# They are not configurable through environment variables yet.
