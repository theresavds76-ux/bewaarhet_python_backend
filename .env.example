# Zoho IMAP/SMTP
ZOHO_EMAIL=service@bewaarhet.nl
ZOHO_IMAP_HOST=imap.zoho.eu
ZOHO_IMAP_PORT=993
ZOHO_SMTP_HOST=smtp.zoho.eu
ZOHO_SMTP_PORT=587
ZOHO_APP_PASSWORD=plak_hier_je_zoho_app_password

# Dropbox
DROPBOX_ACCESS_TOKEN=plak_hier_je_dropbox_access_token
DROPBOX_BASE_PATH=/Bewaar het/Klanten

# OCR.space
OCR_SPACE_API_KEY=plak_hier_je_ocr_space_key
OCR_SPACE_LANGUAGE=dut

# OpenAI fallback, optioneel
OPENAI_API_KEY=plak_hier_je_openai_key
OPENAI_MODEL=gpt-5-mini

# App
DATABASE_PATH=data/bewaarhet.sqlite3
MAX_ATTACHMENT_MB=15
ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.heic,.doc,.docx,.odt,.xls,.xlsx,.ods,.csv,.txt,.rtf,.ppt,.pptx,.odp,.zip
SEARCH_RESULT_LIMIT=10
POLL_SECONDS=60
